# Copy this file to .env and fill in the values
# NEVER commit the actual .env file

PORT=4000
HOST=0.0.0.0

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/webigeeks_prep?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here
ADMIN_JWT_SECRET=your-super-secret-admin-jwt-key-here

# Admin credentials
ADMIN_EMAIL=admin@webigeeks.com
ADMIN_PASSWORD=change-me-in-production

# Frontend origin (your Netlify URL)
CLIENT_ORIGIN=https://your-app.netlify.app
